{
  "name": "@ric/arcade",
  "version": "0.2.0",
  "description": "A deterministic, pluggable party-game engine: seeded RNG, pure game logic, no-cloud lockstep multiplayer. Import the whole arcade or one game. Clone and add your own.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./engine": "./src/engine.js",
    "./transport": "./src/transport.js",
    "./channels/socketio": "./src/channels/socketio.js",
    "./rng": "./src/rng.js",
    "./cards": "./src/cards.js",
    "./grid": "./src/grid.js",
    "./catalog": "./src/catalog.js",
    "./catalog/robotric": "./src/catalog/robotric.js",
    "./games": "./src/games/index.js",
    "./games/*": "./src/games/*.js"
  },
  "files": ["src/"],
  "scripts": {
    "test": "node --test test/*.test.mjs"
  },
  "peerDependencies": {
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "peerDependenciesMeta": {
    "socket.io": { "optional": true },
    "socket.io-client": { "optional": true }
  },
  "license": "MIT"
}
